# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (Docker default)
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/webhookdb?schema=public"

# Redis Connection (Docker default)
REDIS_URL="redis://localhost:6379"

# JWT Security Secrets (change these in production)
JWT_ACCESS_SECRET="super-secret-access-token-key-change-me-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-token-key-change-me-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
